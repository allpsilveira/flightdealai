# ══════════════════════════════════════════════════════════════════════════════
# SECRETS & ENVIRONMENT — never commit these
# ══════════════════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.production
.env.staging
*.env

# API keys, tokens, credentials (catch-all patterns)
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.jks
*.keystore
*_rsa
*_dsa
*_ecdsa
*_ed25519
id_rsa
id_dsa
*.secret
credentials.json
service-account*.json
token.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# ML model artifacts (regenerated weekly by ml_retrain DAG)
ml_models/*.joblib
ml_models/*.pkl
ml_models/*.pt
ml_models/*.h5

# Node
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Airflow
airflow/logs/
airflow/plugins/__pycache__/

# Docker volumes
pgdata/
airflow-logs/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Alembic — keep migrations, ignore cache
backend/alembic/__pycache__/

# Nginx SSL certs (generated on server)
nginx/ssl/

# Backup files that might contain secrets
*.sql
*.dump
*.bak
*.backup
datascience.txt

# Ignore top-level node modules (some projects install at repo root)
node_modules/

# Ignore generated Playwright HTML report
frontend/playwright-report/
