# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=change_me_strong_password
POSTGRES_DB=flightdeal

# ── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_ADMIN_PASSWORD=change_me_admin_password
AIRFLOW_FERNET_KEY=             # python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_SECRET_KEY=             # openssl rand -hex 32

# ── API Keys ──────────────────────────────────────────────────────────────────
# Sign up at serpapi.com — $25/mo, 1,000 searches, primary flight scanner
SERPAPI_API_KEY=

# Sign up at duffel.com — free test key available, $0.005/search in production
DUFFEL_API_KEY=

# Sign up at seats.aero/pricing — $10/mo flat, award availability
SEATS_AERO_API_KEY=

# Sign up at console.anthropic.com — pay-per-use ~$1-5/mo
ANTHROPIC_API_KEY=

# ── Twilio / WhatsApp ─────────────────────────────────────────────────────────
# Sign up at twilio.com — free trial available
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Web Push (VAPID) ──────────────────────────────────────────────────────────
# Generate keys: pip install py-vapid && python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=your@email.com
# Also add VITE_VAPID_PUBLIC_KEY= to the frontend service environment in EasyPanel

# ── App ───────────────────────────────────────────────────────────────────────
JWT_SECRET=                     # openssl rand -hex 64
APP_DOMAIN=localhost             # e.g. flightdeal.yourdomain.com

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
